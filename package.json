{
  "name": "portfolio-2",
  "version": "1.0.0",
  "scripts": {
    "build": "esbuild speed-insights.js --bundle --format=esm --outfile=dist/speed-insights.bundle.js",
    "format": "prettier --write \"**/*.{html,css,js,json}\"",
    "serve": "python -m http.server 8000",
    "lighthouse": "npx lighthouse https://bbgunmis-alt.github.io/my-portfolio-2 --view",
    "deploy": "git add . && git commit -m 'Update portfolio' && git push",
    "gemini-fix": "echo 'Use Continue extension: Cmd+Shift+L to ask Gemini'"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "lighthouse": "^13.3.0",
    "puppeteer": "^24.43.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
